# ── Discord ──────────────────────────────────────────
# Get this from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# The prefix used to invoke bot commands (default: !)
BOT_PREFIX=!

# ── Queue & Auto-Disconnect ───────────────────────────
# Max songs allowed in the queue (default: 50)
MAX_QUEUE=50

# Minutes of inactivity before the bot leaves the channel (default: 5)
AUTO_DISCONNECT_MINUTES=5

# ── DJ Role ──────────────────────────────────────────
# Name of the role that can use DJ-only commands: stop, clear, forceskip
# Users with Manage Server permission bypass this regardless.
DJ_ROLE_NAME=DJ

# ── Spotify (optional) ───────────────────────────────
# Create an app at https://developer.spotify.com/dashboard
# Leave blank to disable Spotify link support.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
